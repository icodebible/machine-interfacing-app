{
  "name": "machine-interfacing-app",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "electron-builder install-app-deps",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:native": "npm run rebuild:native",
    "build:web": "ng build",
    "build:electron": "tsc -p electron/tsconfig.json && node electron/build-preload.mjs",
    "electron:dev-legacy": "concurrently \"npm run build:native\" \"npm run build:electron -- --watch\" \"ng serve\" \"wait-on http://localhost:4200 && cross-env ELECTRON_DEVTOOLS=0 && cross-env ELECTRON_OZONE_PLATFORM_HINT=x11 electron . --ozone-platform=x11 --disable-gpu --disable-gpu-compositing\"",
    "electron:dev": "concurrently \"npm run build:electron -- --watch\" \"ng serve\" \"wait-on http://localhost:4200 && cross-env ELECTRON_DEVTOOLS=0 cross-env ELECTRON_OZONE_PLATFORM_HINT=x11 electron . --ozone-platform=x11 --disable-gpu --disable-gpu-compositing --disable-gpu-sandbox --disable-software-rasterizer\"",
    "electron:build": "npm run build:web && npm run build:electron && electron-builder",
    "clean": "rimraf dist dist-electron release",
    "build:release": "npm run clean && npm run build:web && npm run build:electron",
    "electron:pack": "npm run build:release && electron-builder --dir --publish never",
    "electron:dist": "npm run build:release && electron-builder --publish never",
    "electron:dist:linux": "npm run build:release && electron-builder --linux AppImage deb --x64 --publish never",
    "release:clean": "rimraf release dist dist-electron",
    "apply:material-icons": "node scripts/apply-material-icons-embedded-font-fix.mjs",
    "vendor:material-icons": "node scripts/vendor-material-icons-production.mjs",
    "verify:material-icons": "node scripts/verify-material-icons-embedded-font-fix.mjs",
    "apply:material-icons-runtime": "node scripts/apply-material-icons-runtime-registry-fix.mjs",
    "verify:material-icons-runtime": "node scripts/verify-material-icons-runtime-fix.mjs",
    "icons:scan": "node scripts/scan-offline-svg-icons.mjs",
    "icons:convert": "node scripts/convert-mat-icons-to-svg.mjs",
    "icons:sync": "npm run icons:scan && npm run icons:convert && npm run icons:scan && node scripts/sync-offline-svg-icons.mjs && npm run icons:verify",
    "icons:verify": "node scripts/verify-offline-svg-icons.mjs",
    "package:preflight": "npm run icons:verify && npm run build:release",
    "package:linux": "npm run package:preflight && electron-builder --linux AppImage deb --x64 --publish never && npm run release:checksum",
    "package:windows": "npm run package:preflight && electron-builder --win nsis --x64 --publish never && npm run release:checksum",
    "package:macos": "npm run package:preflight && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --x64 --arm64 --publish never && npm run release:checksum",
    "package:current": "node scripts/package-current-platform.mjs",
    "package:ci": "npm run icons:verify && npm run build:release",
    "release:checksum": "node scripts/create-release-checksums.mjs"
  },
  "build": {
    "appId": "tz.ac.udsm.dhis.machineinterfacing",
    "productName": "Machine Interfacing App",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "npmRebuild": true,
    "extraResources": [
      {
        "from": "electron/resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/512x512.png",
      "category": "Utility",
      "maintainer": "UDSM DHIS2 Lab <dhis2lab@udsm.ac.tz>",
      "vendor": "UDSM DHIS2 Lab",
      "synopsis": "Laboratory analyzer machine interfacing platform"
    },
    "icon": "build/icons/512x512.png",
    "publish": [
      {
        "provider": "github",
        "owner": "icodebible",
        "repo": "machine-interfacing-app",
        "releaseType": "release"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/serialport/**/*",
      "node_modules/@serialport/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Machine Interfacing App"
    }
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.1.0",
    "@angular/compiler": "^20.1.0",
    "@angular/core": "^20.1.0",
    "@angular/forms": "^20.1.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.1.0",
    "@angular/router": "^20.1.0",
    "@fontsource/roboto": "^5.2.10",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "material-design-icons": "^3.0.1",
    "material-icons": "^1.13.14",
    "material-symbols": "^0.35.0",
    "rxjs": "~7.8.0",
    "serialport": "^13.0.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.6",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.1.6",
    "@angular/cli": "^20.1.6",
    "@angular/compiler-cli": "^20.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.7.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "wait-on": "^9.0.4",
    "@material-design-icons/svg": "^0.14.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icodebible/machine-interfacing-app.git"
  },
  "description": "Machine interfacing platform for laboratory analyzer integration, LIS delivery, audit, and deployment readiness.",
  "author": {
    "name": "UDSM DHIS2 Lab",
    "email": "walter.faustine@udsm.ac.tz"
  },
  "homepage": "https://www.dhis2.udsm.ac.tz",
  "license": "UNLICENSED"
}
